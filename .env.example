NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Dentzi"

DATABASE_URL="postgresql://app:app@localhost:5432/dentist_ai?schema=public"
DIRECT_DATABASE_URL="postgresql://app:app@localhost:5432/dentist_ai?schema=public"
REDIS_URL="redis://localhost:6379"

LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="qwen3:30b-a3b"

# OpenAI-compatible LLM endpoint
OPENAI_API_KEY=""
OPENAI_MODEL="openai-gpt-oss-20b"
OPENAI_BASE_URL="https://inference.do-ai.run/v1"

DEFAULT_CLINIC_ID="00000000-0000-0000-0000-000000000001"

APP_TIMEZONE="America/Sao_Paulo"
APP_UTC_OFFSET_MINUTES="-180"
DEFAULT_HOLD_TTL_MINUTES="10"
SCHEDULING_HOLD_TTL_MINUTES="10"
SCHEDULING_SLOT_STEP_MINUTES="30"
WORKING_HOUR_START="8"
WORKING_HOUR_END="19"
MESSAGE_CONTEXT_LIMIT="20"

LOG_LEVEL="debug"

# SMTP (optional — falls back to console log)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

AGENT_MODE="agent"