NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Dentzi"

DATABASE_URL="postgresql://app:app@localhost:5432/dentzi_ai?schema=public"
DIRECT_DATABASE_URL="postgresql://app:app@localhost:5432/dentzi_ai?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── LLM ────────────────────────────────────────────────────
LLM_PROVIDER="openai"                          # ollama | openai | mock
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:30b-a3b"
OPENAI_API_KEY=""
OPENAI_MODEL="openai-gpt-oss-20b"
OPENAI_BASE_URL="https://inference.do-ai.run/v1"

# ─── App ─────────────────────────────────────────────────────
DEFAULT_CLINIC_ID="00000000-0000-0000-0000-000000000001"
APP_TIMEZONE="America/Sao_Paulo"
APP_UTC_OFFSET_MINUTES="-180"
DEFAULT_HOLD_TTL_MINUTES="10"
SCHEDULING_HOLD_TTL_MINUTES="10"
SCHEDULING_SLOT_STEP_MINUTES="30"
WORKING_HOUR_START="8"
WORKING_HOUR_END="19"
MESSAGE_CONTEXT_LIMIT="20"
LOG_LEVEL="debug"
AGENT_MODE="agent"

# ─── Google Calendar (optional — degrades gracefully) ────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# APP_URL is the base URL for this environment:
#   local:   http://localhost:3000
#   develop: https://lionfish-app-w8ks9.ondigitalocean.app
#   prod:    https://app.dentzi.ai  (futuro)
GOOGLE_WEBHOOK_BASE_URL=""                     # = APP_URL
GOOGLE_REDIRECT_URI=""                         # = APP_URL/api/integrations/google-calendar/callback

# ─── SMTP (optional — falls back to console log) ─────────────
SMTP_HOST=""                                   # smtp.gmail.com
SMTP_PORT="587"
SMTP_USER=""                                   # dev@dentzi.ai
SMTP_PASS=""                                   # App Password do Google
SMTP_FROM=""                                   # "Dentzi AI <dev@dentzi.ai>"
